{
  "name": "UMI",
  "version": "0.4.1",
  "description": "Vintage dark industrial UMI theme for Steam — dark graphite chrome, cold light text, scanline grain, orange-edged steel bevels, black inset fields, and hazard-orange activation.",
  "author": "Alex Haynes",
  "header_image": "assets/header.svg",
  "splash_image": "assets/splash.svg",
  "tags": ["Dark", "Vintage", "Industrial", "Textured", "Ornate"],
  "github": {
    "owner": "alexh",
    "repo_name": "umi-millennium-theme"
  },
  "Patches": [
    {
      "MatchRegexString": ".*",
      "TargetCss": "webkit.css"
    },
    {
      "MatchRegexString": "^Steam$",
      "TargetCss": "libraryroot.custom.css",
      "TargetJs": "libraryroot.custom.js"
    },
    {
      "MatchRegexString": "Steam",
      "TargetCss": "libraryroot.custom.css",
      "TargetJs": "libraryroot.custom.js"
    },
    {
      "MatchRegexString": "DesktopUI",
      "TargetCss": "libraryroot.custom.css",
      "TargetJs": "libraryroot.custom.js"
    },
    {
      "MatchRegexString": ".DesktopUI",
      "TargetCss": "libraryroot.custom.css",
      "TargetJs": "libraryroot.custom.js"
    },
    {
      "MatchRegexString": ".friendsui-container",
      "TargetCss": "friends.custom.css",
      "TargetJs": "friends.custom.js"
    },
    {
      "MatchRegexString": ".fullheight",
      "TargetCss": "bigpicture.custom.css",
      "TargetJs": "bigpicture.custom.js"
    }
  ]
}
